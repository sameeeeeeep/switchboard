{
  "manifest_version": 3,
  "name": "Switchboard",
  "version": "0.1.0",
  "description": "Bring your own AI. Lend any website your Claude, tools, context and data — under per-site consent. MetaMask, but for AI.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Switchboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": ["storage", "tabs", "downloads", "sidePanel"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"]
}
