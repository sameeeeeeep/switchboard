{
  "manifest_version": 3,
  "name": "Switchboard",
  "version": "0.1.4",
  "description": "Bring your own AI. Lend any website your Claude, tools, context and data \u2014 under per-site consent. MetaMask, but for AI.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Switchboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://thelastprompt.ai/*",
        "https://*.thelastprompt.ai/*",
        "https://sameeeeeeep.github.io/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://thelastprompt.ai/*",
        "https://*.thelastprompt.ai/*",
        "https://sameeeeeeep.github.io/*",
        "http://127.0.0.1/*",
        "http://localhost/*",
        "*://adsmanager.facebook.com/*",
        "*://business.facebook.com/*",
        "*://ads.tiktok.com/*",
        "*://adcreative.ai/*",
        "*://*.adcreative.ai/*",
        "*://photoroom.com/*",
        "*://*.photoroom.com/*",
        "*://pebblely.com/*",
        "*://*.pebblely.com/*",
        "*://costarastrology.com/*",
        "*://*.costarastrology.com/*",
        "*://notion.so/*",
        "*://*.notion.so/*",
        "*://obsidian.md/*",
        "*://*.obsidian.md/*",
        "*://spira.ai/*",
        "*://*.spira.ai/*",
        "*://arcads.ai/*",
        "*://*.arcads.ai/*",
        "*://captions.ai/*",
        "*://*.captions.ai/*",
        "*://canva.com/*",
        "*://*.canva.com/*",
        "*://figma.com/*",
        "*://*.figma.com/*",
        "*://adobe.com/*",
        "*://*.adobe.com/*",
        "*://leonardo.ai/*",
        "*://*.leonardo.ai/*"
      ],
      "js": [
        "dist/widget.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/inject.js"
      ],
      "matches": [
        "https://thelastprompt.ai/*",
        "https://*.thelastprompt.ai/*",
        "https://sameeeeeeep.github.io/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ]
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "sidePanel",
    "notifications",
    "favicon"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ]
}