{
  "manifest_version": 3,
  "name": "Relay — BYO-Claude",
  "version": "0.0.1",
  "description": "Lend any website your own Claude + connected tools, under per-site consent. MetaMask, but for AI.",
  "action": {
    "default_title": "Relay"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": ["storage", "tabs", "downloads", "sidePanel"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"]
}
