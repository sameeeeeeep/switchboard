{
  "name": "@relay/sidekick",
  "version": "0.0.0",
  "description": "The relay sidekick daemon — owns the user's model backends (Claude Code + local runners) and MCP tools, and is the sole out-of-band enforcement point for per-origin permissions and consent.",
  "type": "module",
  "bin": {
    "relay-sidekick": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json && node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.202",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@relay/protocol": "*",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10"
  }
}
